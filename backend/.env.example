# ─── Backend Environment Variables ───
# Copy to .env and fill in real values. Never commit the real .env.

# PostgreSQL (AWS RDS) connection string
DATABASE_URL="postgresql://USER:PASSWORD@your-rds-endpoint.amazonaws.com:5432/postgres?schema=public&sslmode=require"

# Google Gemini API key (https://aistudio.google.com)
GEMINI_API_KEY="your-gemini-api-key"

# AWS S3 (product + condition images)
AWS_REGION="eu-north-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
S3_BUCKET="your-bucket-name"

# JWT signing secret (use a long random string in production)
JWT_SECRET="change-this-to-a-long-random-secret"

# Server port
PORT=5000
