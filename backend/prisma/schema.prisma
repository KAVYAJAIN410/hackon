generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @map("id")
  name        String
  category    String
  brand       String?
  mrp         Decimal  @db.Decimal(10, 2)
  imageUrl    String?  @map("image_url")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  orders         Order[]
  inventoryItems InventoryItem[]

  @@map("products")
}

model User {
  id           String   @id @map("id")
  name         String
  email        String   @unique
  city         String
  state        String
  greenCredits Int      @default(0) @map("green_credits")
  greenTier    String   @default("SEEDLING") @map("green_tier")
  nearestDcId  String?  @map("nearest_dc_id")
  createdAt    DateTime @default(now()) @map("created_at")
  loginId      String?  @unique @map("login_id")

  login             LoginCredentials?   @relation(fields: [loginId], references: [id])
  nearestDc         DeliveryCenter?     @relation(fields: [nearestDcId], references: [id])
  orders            Order[]
  returns           Return[]
  marketplaceOrders MarketplaceOrder[]
  greenCreditLedger GreenCreditLedger[]

  @@map("users")
}

model DeliveryCenter {
  id   String @id @map("id")
  name String
  city String
  type String @default("WAREHOUSE")

  users              User[]
  sourceRoutes       DcRoute[]           @relation("SourceDc")
  destRoutes         DcRoute[]           @relation("DestDc")
  returnsAtDc        Return[]
  inventoryItemsAtDc InventoryItem[]
  DeliveryAssociate  DeliveryAssociate[]

  @@map("delivery_centers")
}

model DcRoute {
  id            String  @id @default(uuid()) @map("id")
  sourceDcId    String  @map("source_dc_id")
  destDcId      String  @map("dest_dc_id")
  distance      Int
  transferCost  Decimal @map("transfer_cost") @db.Decimal(10, 2)
  estimatedDays Int     @map("estimated_days")

  sourceDc DeliveryCenter @relation("SourceDc", fields: [sourceDcId], references: [id])
  destDc   DeliveryCenter @relation("DestDc", fields: [destDcId], references: [id])

  @@unique([sourceDcId, destDcId])
  @@map("dc_routes")
}

model Order {
  id        String   @id @map("id")
  userId    String   @map("user_id")
  productId String   @map("product_id")
  status    String   @default("DELIVERED")
  orderedAt DateTime @default(now()) @map("ordered_at")
  sellerId  String?  @map("seller_id")

  seller  Seller?  @relation(fields: [sellerId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  product Product  @relation(fields: [productId], references: [id])
  returns Return[]

  @@index([userId])
  @@index([productId])
  @@map("orders")
}

model Return {
  id                String   @id @default(uuid()) @map("id")
  orderId           String   @map("order_id")
  userId            String   @map("user_id")
  reason            String
  status            String   @default("INITIATED")
  returnMethod      String?  @map("return_method")
  refundAmount      Decimal? @map("refund_amount") @db.Decimal(10, 2)
  currentDcId       String?  @map("current_dc_id")
  routeDecision     String?  @map("route_decision")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  pickupAssociateId String?  @map("pickup_associate_id")

  pickupAssociate DeliveryAssociate? @relation(fields: [pickupAssociateId], references: [id])
  order           Order              @relation(fields: [orderId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
  currentDc       DeliveryCenter?    @relation(fields: [currentDcId], references: [id])
  images          ReturnImage[]
  gradings        AiGrading[]
  finalGrading    FinalGrading?
  inventoryItem   InventoryItem?

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("returns")
}

model ReturnImage {
  id        String   @id @default(uuid()) @map("id")
  returnId  String   @map("return_id")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  return Return @relation(fields: [returnId], references: [id])

  @@map("return_images")
}

model AiGrading {
  id                   String   @id @default(uuid()) @map("id")
  returnId             String   @map("return_id")
  grade                String
  score                Int
  confidence           Decimal  @db.Decimal(5, 2)
  conditionSummary     String?  @map("condition_summary") @db.Text
  defectsFound         Json?    @map("defects_found")
  missingParts         Json?    @map("missing_parts")
  functionalNotes      String?  @map("functional_notes") @db.Text
  estimatedResaleValue Decimal? @map("estimated_resale_value") @db.Decimal(10, 2)
  gradeDiscountPct     Int      @map("grade_discount_pct")
  routeDecision        String?  @map("route_decision")
  gradedBy             String   @default("USER") @map("graded_by") // 'USER' or 'DELIVERY_ASSOCIATE'
  createdAt            DateTime @default(now()) @map("created_at")

  return Return @relation(fields: [returnId], references: [id])

  @@map("ai_gradings")
}

model FinalGrading {
  id                   String   @id @default(uuid()) @map("id")
  returnId             String   @unique @map("return_id")
  grade                String
  score                Int
  confidence           Decimal  @db.Decimal(5, 2)
  conditionSummary     String?  @map("condition_summary") @db.Text
  defectsFound         Json?    @map("defects_found")
  missingParts         Json?    @map("missing_parts")
  functionalNotes      String?  @map("functional_notes") @db.Text
  estimatedResaleValue Decimal? @map("estimated_resale_value") @db.Decimal(10, 2)
  gradeDiscountPct     Int      @map("grade_discount_pct")
  routeDecision        String?  @map("route_decision")
  createdAt            DateTime @default(now()) @map("created_at")

  return Return @relation(fields: [returnId], references: [id])

  @@map("final_gradings")
}

model InventoryItem {
  id           String   @id @default(uuid()) @map("id")
  returnId     String?  @unique @map("return_id")
  productId    String   @map("product_id")
  currentDcId  String   @map("current_dc_id")
  status       String   @default("AVAILABLE")
  grade        String
  basePrice    Decimal  @map("base_price") @db.Decimal(10, 2)
  sellingPrice Decimal  @map("selling_price") @db.Decimal(10, 2)
  source       String   @default("RETURN")
  createdAt    DateTime @default(now()) @map("created_at")

  // ─── Outgrown / resell-specific fields (when source = 'OUTGROWN') ───
  listedByUserId   String?  @map("listed_by_user_id")
  sourceOrderId    String?  @map("source_order_id")
  ageMonths        Int?     @map("age_months")
  conditionAnswers Json?    @map("condition_answers")
  gradingData      Json?    @map("grading_data")     // { grade, score, confidence, conditionSummary, defectsFound, missingParts }
  healthImages     String[] @map("health_images")

  return           Return?           @relation(fields: [returnId], references: [id])
  product          Product           @relation(fields: [productId], references: [id])
  currentDc        DeliveryCenter    @relation(fields: [currentDcId], references: [id])
  marketplaceOrder MarketplaceOrder?

  @@index([status])
  @@index([currentDcId])
  @@index([grade])
  @@map("inventory_items")
}

model MarketplaceOrder {
  id              String   @id @default(uuid()) @map("id")
  inventoryItemId String   @unique @map("inventory_item_id")
  buyerId         String   @map("buyer_id")
  sellingPrice    Decimal  @map("selling_price") @db.Decimal(10, 2)
  shippingCost    Decimal  @map("shipping_cost") @db.Decimal(10, 2)
  totalPrice      Decimal  @map("total_price") @db.Decimal(10, 2)
  status          String   @default("CONFIRMED")
  createdAt       DateTime @default(now()) @map("created_at")

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  buyer         User          @relation(fields: [buyerId], references: [id])

  @@map("marketplace_orders")
}

model GradeConfig {
  id           String   @id @default(uuid()) @map("id")
  grade        String   @unique
  label        String
  discountPct  Int      @map("discount_pct")
  defaultRoute String   @map("default_route")
  minMrp       Decimal? @map("min_mrp") @db.Decimal(10, 2)

  @@map("grade_configs")
}

model GreenCreditLedger {
  id          String   @id @default(uuid()) @map("id")
  userId      String   @map("user_id")
  amount      Int
  action      String
  referenceId String?  @map("reference_id")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("green_credit_ledger")
}

model LoginCredentials {
  id           String @id @default(uuid()) @map("id")
  email        String @unique @map("email")
  passwordHash String @map("password_hash")
  role         String @default("CUSTOMER") @map("role") // 'ADMIN', 'CUSTOMER', 'DELIVERY_PARTNER', 'SELLER'

  user              User?
  admin             Admin?
  deliveryAssociate DeliveryAssociate?
  seller            Seller?

  @@map("login_credentials")
}

model Admin {
  id    String @id @default(uuid()) @map("id")
  name  String
  email String @unique

  loginId String?           @unique @map("login_id")
  login   LoginCredentials? @relation(fields: [loginId], references: [id])

  @@map("admins")
}

model DeliveryAssociate {
  id            String  @id @default(uuid()) @map("id")
  name          String
  email         String  @unique
  phone         String?
  vehicleType   String? @map("vehicle_type")
  vehicleNumber String? @map("vehicle_number")
  currentStatus String  @default("OFF_DUTY") // 'OFF_DUTY', 'AVAILABLE', 'ON_DELIVERY'
  assignedDcId  String? @map("assigned_dc_id")

  assignedDc DeliveryCenter? @relation(fields: [assignedDcId], references: [id])

  loginId String?           @unique @map("login_id")
  login   LoginCredentials? @relation(fields: [loginId], references: [id])
  pickups Return[] // Link to assigned returns

  @@map("delivery_associates")
}

model Seller {
  id           String  @id @default(uuid()) @map("id")
  businessName String  @map("business_name")
  contactName  String  @map("contact_name")
  email        String  @unique
  phone        String?
  taxId        String? @map("tax_id") // e.g., GSTIN
  address      String?
  city         String?
  state        String?
  status       String  @default("PENDING") // 'PENDING', 'APPROVED', 'SUSPENDED'

  loginId String?           @unique @map("login_id")
  login   LoginCredentials? @relation(fields: [loginId], references: [id])
  orders  Order[]

  @@map("sellers")
}
